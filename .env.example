# ──────────────────────────────────────────────
# Multimodal Math Mentor — Environment Variables
# Copy this file to .env and fill in values.
# ──────────────────────────────────────────────

# ── LLM Provider (openai | groq | anthropic) ──
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Groq (alternative)
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# Anthropic / Claude (alternative)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Google Gemini (alternative)
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-1.5-flash

# ── Embeddings ──
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── OCR ──
OCR_ENGINE=auto
OCR_CONFIDENCE_THRESHOLD=0.7

# Vision OCR models (used for image-to-math OCR, independent of chat model)
# Engine priority: mathpix → llm_vision → easyocr
# Set OCR_ENGINE=easyocr to force offline mode, OCR_ENGINE=llm_vision to force LLM vision.
OPENAI_VISION_MODEL=gpt-4o
GROQ_VISION_MODEL=llama-3.2-11b-vision-preview
ANTHROPIC_VISION_MODEL=claude-3-haiku-20240307
GEMINI_VISION_MODEL=gemini-1.5-flash

# ── Verifier ──
VERIFIER_CONFIDENCE_THRESHOLD=0.75

# ── RAG ──
CHROMA_PERSIST_DIR=./data/chroma_db
RAG_TOP_K=5
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ── Memory DB ──
SQLITE_DB_PATH=./data/memory.db

# ── Logging ──
LOG_LEVEL=INFO
